{
  "info": {
    "_postman_id": "2f6ebd0f-3f6f-4f7d-8aa9-7ea2c9d7c4f1",
    "name": "WorldCovers API v2",
    "description": "Postman collection for the unified Marking / polymorphic Image / Cover-side observations API. Routes mirror backend/common/api/v2/urls.py.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "noauth"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": "{{baseUrl}}/api/v2/login/"
          }
        },
        { "name": "Logout", "request": { "method": "POST", "url": "{{baseUrl}}/api/v2/logout/" } },
        { "name": "Current User", "request": { "method": "GET", "url": "{{baseUrl}}/api/v2/me/" } },
        {
          "name": "Login Request (signup)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"newuser@example.com\",\n  \"first_name\": \"Jane\",\n  \"last_name\": \"Doe\"\n}"
            },
            "url": "{{baseUrl}}/api/v2/login-requests/"
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"user@example.com\"\n}" },
            "url": "{{baseUrl}}/api/v2/forgot-password/"
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"token\": \"<token-from-email>\",\n  \"new_password\": \"newpass123\"\n}" },
            "url": "{{baseUrl}}/api/v2/reset-password/"
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"current_password\": \"{{password}}\",\n  \"new_password\": \"newpass123\"\n}" },
            "url": "{{baseUrl}}/api/v2/change-password/"
          }
        },
        { "name": "Help Docs", "request": { "method": "GET", "url": "{{baseUrl}}/api/v2/help-docs/" } }
      ]
    },
    {
      "name": "Lookups (Geography + Reference)",
      "item": [
        { "name": "Regions List", "request": { "method": "GET", "url": "{{baseUrl}}/api/v2/regions/" } },
        {
          "name": "Regions Create",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Virginia\",\n  \"abbrev\": \"VA\",\n  \"region_tier\": \"STATE\"\n}" },
            "url": "{{baseUrl}}/api/v2/regions/"
          }
        },
        { "name": "Regions Retrieve", "request": { "method": "GET", "url": "{{baseUrl}}/api/v2/regions/{{region_id}}/" } },
        { "name": "Regions Delete", "request": { "method": "DELETE", "url": "{{baseUrl}}/api/v2/regions/{{region_id}}/" } },

        { "name": "Post Offices List", "request": { "method": "GET", "url": "{{baseUrl}}/api/v2/post-offices/" } },
        {
          "name": "Post Offices Create",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Richmond\",\n  \"region\": {{region_id}}\n}" },
            "url": "{{baseUrl}}/api/v2/post-offices/"
          }
        },
        { "name": "Post Offices Retrieve", "request": { "method": "GET", "url": "{{baseUrl}}/api/v2/post-offices/{{post_office_id}}/" } },
        { "name": "Post Offices Delete", "request": { "method": "DELETE", "url": "{{baseUrl}}/api/v2/post-offices/{{post_office_id}}/" } },

        { "name": "Letterings List", "request": { "method": "GET", "url": "{{baseUrl}}/api/v2/letterings/" } },
        { "name": "Shapes List", "request": { "method": "GET", "url": "{{baseUrl}}/api/v2/shapes/" } },
        { "name": "Colors List", "request": { "method": "GET", "url": "{{baseUrl}}/api/v2/colors/" } },

        { "name": "Reference Works List", "request": { "method": "GET", "url": "{{baseUrl}}/api/v2/reference-works/" } },
        {
          "name": "Reference Works Create",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"code\": \"APMC\",\n  \"title\": \"American Postal Markings Compendium\"\n}" },
            "url": "{{baseUrl}}/api/v2/reference-works/"
          }
        },
        { "name": "Reference Works Retrieve", "request": { "method": "GET", "url": "{{baseUrl}}/api/v2/reference-works/{{reference_work_id}}/" } }
      ]
    },
    {
      "name": "Catalog (Markings)",
      "item": [
        { "name": "Markings List", "request": { "method": "GET", "url": "{{baseUrl}}/api/v2/markings/" } },
        {
          "name": "Markings Create",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"APMC-VA-1\",\n  \"type\": \"TOWNMARK\",\n  \"is_manuscript\": false,\n  \"post_office\": {{post_office_id}},\n  \"shape\": {{shape_id}},\n  \"lettering\": {{lettering_id}},\n  \"color\": {{color_id}},\n  \"is_irreg\": false,\n  \"impression\": \"Normal\",\n  \"rate_val\": \"\"\n}"
            },
            "url": "{{baseUrl}}/api/v2/markings/"
          }
        },
        { "name": "Markings Retrieve", "request": { "method": "GET", "url": "{{baseUrl}}/api/v2/markings/{{marking_id}}/" } },
        {
          "name": "Markings Update",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"impression\": \"Heavy\"\n}" },
            "url": "{{baseUrl}}/api/v2/markings/{{marking_id}}/"
          }
        },
        { "name": "Markings Delete", "request": { "method": "DELETE", "url": "{{baseUrl}}/api/v2/markings/{{marking_id}}/" } },
        { "name": "Markings Delete Mine", "request": { "method": "DELETE", "url": "{{baseUrl}}/api/v2/markings/{{marking_id}}/delete-mine/" } },
        { "name": "Markings Date Range", "request": { "method": "GET", "url": "{{baseUrl}}/api/v2/markings-range/" } }
      ]
    },
    {
      "name": "Catalog (Images polymorphic)",
      "item": [
        { "name": "Images List", "request": { "method": "GET", "url": "{{baseUrl}}/api/v2/images/" } },
        {
          "name": "Images Create (Marking)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"subject_type\": \"MARKING\",\n  \"subject_id\": {{marking_id}},\n  \"image_url\": \"https://example.com/img.jpg\"\n}"
            },
            "url": "{{baseUrl}}/api/v2/images/"
          }
        },
        { "name": "Images Retrieve", "request": { "method": "GET", "url": "{{baseUrl}}/api/v2/images/{{image_id}}/" } },
        { "name": "Images Delete", "request": { "method": "DELETE", "url": "{{baseUrl}}/api/v2/images/{{image_id}}/" } }
      ]
    },
    {
      "name": "Catalog (Citations)",
      "item": [
        { "name": "Citations List", "request": { "method": "GET", "url": "{{baseUrl}}/api/v2/citations/" } },
        {
          "name": "Citations Create",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reference_work\": {{reference_work_id}},\n  \"subject_type\": \"MARKING\",\n  \"subject_id\": {{marking_id}},\n  \"citation_detail\": \"419\"\n}"
            },
            "url": "{{baseUrl}}/api/v2/citations/"
          }
        },
        { "name": "Citations Retrieve", "request": { "method": "GET", "url": "{{baseUrl}}/api/v2/citations/{{citation_id}}/" } },
        { "name": "Citations Delete", "request": { "method": "DELETE", "url": "{{baseUrl}}/api/v2/citations/{{citation_id}}/" } }
      ]
    },
    {
      "name": "Covers + Observations",
      "item": [
        { "name": "Covers List", "request": { "method": "GET", "url": "{{baseUrl}}/api/v2/covers/" } },
        {
          "name": "Covers Create",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"APMC-VA/CV1\",\n  \"color\": {{color_id}},\n  \"has_adhesive\": false,\n  \"is_institutional\": false\n}"
            },
            "url": "{{baseUrl}}/api/v2/covers/"
          }
        },
        { "name": "Covers Retrieve", "request": { "method": "GET", "url": "{{baseUrl}}/api/v2/covers/{{cover_id}}/" } },
        { "name": "Covers Delete", "request": { "method": "DELETE", "url": "{{baseUrl}}/api/v2/covers/{{cover_id}}/" } },

        { "name": "Cover Markings List", "request": { "method": "GET", "url": "{{baseUrl}}/api/v2/cover-markings/" } },
        {
          "name": "Cover Markings Create",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cover\": {{cover_id}},\n  \"marking\": {{marking_id}},\n  \"is_backstamp\": false,\n  \"placement\": null\n}"
            },
            "url": "{{baseUrl}}/api/v2/cover-markings/"
          }
        },
        { "name": "Cover Markings Retrieve", "request": { "method": "GET", "url": "{{baseUrl}}/api/v2/cover-markings/{{cover_marking_id}}/" } },
        { "name": "Cover Markings Delete", "request": { "method": "DELETE", "url": "{{baseUrl}}/api/v2/cover-markings/{{cover_marking_id}}/" } },

        { "name": "Cover Dates List", "request": { "method": "GET", "url": "{{baseUrl}}/api/v2/cover-dates/" } },
        {
          "name": "Cover Dates Create",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cover\": {{cover_id}},\n  \"date\": \"1855-04-12\",\n  \"granularity\": \"DAY\"\n}"
            },
            "url": "{{baseUrl}}/api/v2/cover-dates/"
          }
        },
        { "name": "Cover Dates Retrieve", "request": { "method": "GET", "url": "{{baseUrl}}/api/v2/cover-dates/{{cover_date_id}}/" } },
        { "name": "Cover Dates Delete", "request": { "method": "DELETE", "url": "{{baseUrl}}/api/v2/cover-dates/{{cover_date_id}}/" } },

        { "name": "Cover Valuations List", "request": { "method": "GET", "url": "{{baseUrl}}/api/v2/cover-valuations/" } },
        {
          "name": "Cover Valuations Create",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cover\": {{cover_id}},\n  \"amt\": 250.00,\n  \"appraisal_date\": null\n}"
            },
            "url": "{{baseUrl}}/api/v2/cover-valuations/"
          }
        },
        { "name": "Cover Valuations Retrieve", "request": { "method": "GET", "url": "{{baseUrl}}/api/v2/cover-valuations/{{cover_valuation_id}}/" } },
        { "name": "Cover Valuations Delete", "request": { "method": "DELETE", "url": "{{baseUrl}}/api/v2/cover-valuations/{{cover_valuation_id}}/" } }
      ]
    },
    {
      "name": "Moderation + Governance",
      "item": [
        { "name": "Contributions List", "request": { "method": "GET", "url": "{{baseUrl}}/api/v2/contributions/" } },
        { "name": "Contributions Retrieve", "request": { "method": "GET", "url": "{{baseUrl}}/api/v2/contributions/{{contribution_id}}/" } },
        {
          "name": "Contributions Approve",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"note\": \"Approved.\"\n}" },
            "url": "{{baseUrl}}/api/v2/contributions/{{contribution_id}}/approve/"
          }
        },
        {
          "name": "Contributions Reject",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"note\": \"Rejected: missing source.\"\n}" },
            "url": "{{baseUrl}}/api/v2/contributions/{{contribution_id}}/reject/"
          }
        },
        {
          "name": "Contributions Request Revision",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"note\": \"Please clarify date source.\"\n}" },
            "url": "{{baseUrl}}/api/v2/contributions/{{contribution_id}}/request-revision/"
          }
        },

        { "name": "Collections List", "request": { "method": "GET", "url": "{{baseUrl}}/api/v2/collections/" } },
        { "name": "Collections Retrieve", "request": { "method": "GET", "url": "{{baseUrl}}/api/v2/collections/{{collection_id}}/" } },

        { "name": "FAQ Entries List", "request": { "method": "GET", "url": "{{baseUrl}}/api/v2/faq-entries/" } }
      ]
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://127.0.0.1:8000" },
    { "key": "username", "value": "admin" },
    { "key": "password", "value": "admin" },
    { "key": "region_id", "value": "1" },
    { "key": "post_office_id", "value": "1" },
    { "key": "shape_id", "value": "1" },
    { "key": "lettering_id", "value": "1" },
    { "key": "color_id", "value": "1" },
    { "key": "reference_work_id", "value": "1" },
    { "key": "marking_id", "value": "1" },
    { "key": "image_id", "value": "1" },
    { "key": "citation_id", "value": "1" },
    { "key": "cover_id", "value": "1" },
    { "key": "cover_marking_id", "value": "1" },
    { "key": "cover_date_id", "value": "1" },
    { "key": "cover_valuation_id", "value": "1" },
    { "key": "contribution_id", "value": "1" },
    { "key": "collection_id", "value": "1" }
  ]
}
