# Supabase (current data source)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=

# Django API (auth, filters, postmarks, etc.). For local dev use http://127.0.0.1:8000 or leave unset.
# When the app is opened from a non-local host (e.g. hellowoco.app), the runtime uses that origin + /api automatically.
# VITE_API_BASE_URL=http://127.0.0.1:8000

# Optional: external APIs. When set, options are loaded from the API; otherwise from Supabase.
# Example: https://api.example.com
VITE_COLORS_API_URL=
VITE_POSTAL_FACILITIES_API_URL=
VITE_POSTAL_FACILITY_IDENTITIES_API_URL=
VITE_POSTMARK_SHAPES_API_URL=
VITE_LETTERING_STYLES_API_URL=
VITE_FRAMING_STYLES_API_URL=
VITE_DATE_FORMATS_API_URL=
VITE_POSTMARKS_API_URL=
VITE_POSTMARK_IMAGES_API_URL=
VITE_POSTMARK_VALUATIONS_API_URL=
VITE_PUBLICATIONS_API_URL=
VITE_PUBLICATION_REFERENCES_API_URL=
VITE_POSTCOVERS_API_URL=
